{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JairusSW/as-test/blob/main/as-test.config.schema.json",
  "title": "as-test configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor validation/autocomplete."
    },
    "input": {
      "type": "array",
      "description": "Glob patterns for test specification files.",
      "items": {
        "type": "string"
      },
      "default": ["./assembly/__tests__/*.spec.ts"]
    },
    "output": {
      "description": "Output alias. Use a root string or a per-artifact object. Legacy fields (outDir/logs/coverageDir/snapshotDir) still work and override this alias when both are set.",
      "oneOf": [
        {
          "type": "string",
          "description": "Root output directory. Expands to build/logs/coverage/snapshots subdirectories."
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "build": {
              "type": "string",
              "description": "Build artifact output directory (maps to outDir)."
            },
            "logs": {
              "type": "string",
              "description": "Log artifact output directory (maps to logs). Use \"none\" to disable."
            },
            "coverage": {
              "type": "string",
              "description": "Coverage artifact output directory (maps to coverageDir). Use \"none\" to disable."
            },
            "snapshots": {
              "type": "string",
              "description": "Snapshot output directory (maps to snapshotDir)."
            }
          }
        }
      ]
    },
    "outDir": {
      "type": "string",
      "description": "Directory where compiled artifacts are written.",
      "default": "./.as-test/build"
    },
    "logs": {
      "description": "Directory for log artifacts, or \"none\" to disable.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "const": "none"
        }
      ],
      "default": "./.as-test/logs"
    },
    "coverageDir": {
      "description": "Directory for coverage artifacts, or \"none\" to disable writing coverage files.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "const": "none"
        }
      ],
      "default": "./.as-test/coverage"
    },
    "snapshotDir": {
      "type": "string",
      "description": "Directory for snapshot files written by snapshot assertions.",
      "default": "./.as-test/snapshots"
    },
    "config": {
      "type": "string",
      "description": "Reserved config field used by existing projects.",
      "default": "none"
    },
    "coverage": {
      "description": "Coverage settings. Use a boolean for quick toggle or object for options.",
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "includeSpecs": {
              "type": "boolean",
              "description": "Include *.spec.ts files in coverage collection.",
              "default": false
            }
          }
        }
      ],
      "default": true
    },
    "env": {
      "description": "Environment variables injected when building/running. Accepts a .env file path, an array of KEY=value strings, or an object map.",
      "oneOf": [
        {
          "type": "string",
          "description": "Path to a .env file, resolved relative to the config file."
        },
        {
          "type": "array",
          "description": "Inline environment entries in KEY=value form.",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      ],
      "default": {}
    },
    "buildOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cmd": {
          "type": "string",
          "description": "Custom build command template. When set, this replaces the default asc command/flags/output handling. Supports placeholders: <file>, <name>, <outFile>, <target>, <mode>.",
          "default": ""
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "target": {
          "type": "string",
          "enum": ["wasi", "bindings", "web"],
          "default": "wasi"
        },
        "env": {
          "description": "Build-only environment overrides. Merges with top-level env and mode env.",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ],
          "default": {}
        }
      },
      "default": {
        "cmd": "",
        "args": [],
        "target": "wasi",
        "env": {}
      }
    },
    "fuzz": {
      "type": "object",
      "additionalProperties": false,
      "description": "Fuzz target configuration used by `ast fuzz` and `ast test --fuzz`.",
      "properties": {
        "input": {
          "type": "array",
          "description": "Glob patterns for fuzz target files.",
          "items": {
            "type": "string"
          },
          "default": ["./assembly/__fuzz__/*.fuzz.ts"]
        },
        "entry": {
          "type": "string",
          "description": "Exported fuzz entry name.",
          "default": "fuzz"
        },
        "runs": {
          "type": "number",
          "description": "Number of fuzz iterations per target.",
          "default": 1000
        },
        "seed": {
          "type": "number",
          "description": "Base deterministic seed for input mutation.",
          "default": 1337
        },
        "maxInputBytes": {
          "type": "number",
          "description": "Maximum generated input size in bytes.",
          "default": 4096
        },
        "target": {
          "type": "string",
          "enum": ["bindings"],
          "description": "Fuzz builds currently require bindings output.",
          "default": "bindings"
        },
        "corpusDir": {
          "type": "string",
          "description": "Directory containing per-target seed corpus files.",
          "default": "./.as-test/fuzz/corpus"
        },
        "crashDir": {
          "type": "string",
          "description": "Directory where crashing inputs and metadata are written.",
          "default": "./.as-test/fuzz/crashes"
        }
      },
      "default": {
        "input": ["./assembly/__fuzz__/*.fuzz.ts"],
        "entry": "fuzz",
        "runs": 1000,
        "seed": 1337,
        "maxInputBytes": 4096,
        "target": "bindings",
        "corpusDir": "./.as-test/fuzz/corpus",
        "crashDir": "./.as-test/fuzz/crashes"
      }
    },
    "modes": {
      "type": "object",
      "description": "Named build/run modes. Each mode can override target/args/runtime/env and artifact directories.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "outDir": {
            "type": "string",
            "description": "Mode-specific build output directory. If omitted, defaults to <outDir>/<mode-name>."
          },
          "logs": {
            "type": "string",
            "description": "Mode-specific log output directory."
          },
          "coverageDir": {
            "type": "string",
            "description": "Mode-specific coverage output directory."
          },
          "snapshotDir": {
            "type": "string",
            "description": "Mode-specific snapshot directory."
          },
          "config": {
            "type": "string",
            "description": "Mode-specific asconfig path or \"none\"."
          },
          "coverage": {
            "description": "Mode-specific coverage settings.",
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "includeSpecs": {
                    "type": "boolean"
                  }
                }
              }
            ]
          },
          "buildOptions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "cmd": {
                "type": "string",
                "description": "Mode-specific custom build command template."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "target": {
                "type": "string",
                "enum": ["wasi", "bindings", "web"]
              },
              "env": {
                "description": "Mode-specific build environment overrides.",
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                ]
              }
            }
          },
          "runOptions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "runtime": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "cmd": {
                    "type": "string",
                    "description": "Mode-specific runtime command."
                  }
                }
              },
              "reporter": {
                "description": "Mode-specific reporter config.",
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "options": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "outDir": {
                        "type": "string"
                      },
                      "outFile": {
                        "type": "string"
                      }
                    },
                    "required": ["name"]
                  }
                ]
              },
              "env": {
                "description": "Mode-specific runtime environment overrides.",
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                ]
              }
            }
          },
          "env": {
            "description": "Mode-wide environment variables merged before build/run-specific env.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          }
        }
      },
      "default": {}
    },
    "runOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cmd": {
              "type": "string",
              "description": "Runtime command; supports placeholders like <file> and <name>.",
              "default": "node ./.as-test/runners/default.wasi.js <file>"
            }
          },
          "default": {
            "cmd": "node ./.as-test/runners/default.wasi.js <file>"
          }
        },
        "reporter": {
          "description": "Reporter selection. Use a string for built-in/default/custom path, or an object for named reporter configuration.",
          "oneOf": [
            {
              "type": "string",
              "description": "\"\" or \"default\" uses built-in default reporter, \"tap\" uses built-in TAP v13 reporter, otherwise treated as custom module path."
            },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Reporter name or module path. Built-in values: \"default\", \"tap\"."
                },
                "options": {
                  "type": "array",
                  "description": "Reporter options. TAP supports \"single-file\" (default) and \"per-file\".",
                  "items": {
                    "type": "string"
                  }
                },
                "outDir": {
                  "type": "string",
                  "description": "TAP output directory. Defaults to \"./.as-test/reports\"."
                },
                "outFile": {
                  "type": "string",
                  "description": "TAP output file path for single-file mode. Defaults to \"./.as-test/reports/report.tap\"."
                }
              },
              "required": ["name"]
            }
          ],
          "default": ""
        },
        "env": {
          "description": "Run-only environment overrides. Merges with top-level env and mode env.",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ],
          "default": {}
        }
      },
      "default": {
        "runtime": {
          "cmd": "node ./.as-test/runners/default.wasi.js <file>"
        },
        "reporter": "",
        "env": {}
      }
    }
  }
}
