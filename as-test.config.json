{
  "$schema": "./as-test.config.schema.json",
  "input": ["assembly/__tests__/**/*.spec.ts", "!**/__tmp_*"],
  "config": "none",
  "coverage": true,
  "features": ["try-as"],
  "env": {},
  "fuzz": {
    "input": ["assembly/__fuzz__/**/*.fuzz.ts"],
    "runs": 1000,
    "seed": 1337,
    "maxInputBytes": 4096,
    "target": "bindings",
    "corpusDir": ".as-test/fuzz/corpus",
    "crashDir": ".as-test/crashes"
  },
  "buildOptions": {
    "target": "wasi"
  },
  "modes": {
    "node:bindings": {
      "buildOptions": {
        "target": "bindings"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.bindings.js"
        }
      }
    },
    "node:bindings:raw": {
      "default": false,
      "buildOptions": {
        "target": "bindings",
        "args": ["--bindings raw"]
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.bindings.js"
        }
      }
    },
    "node:bindings:esm": {
      "default": false,
      "input": [
        "assembly/__tests__/**/*.spec.ts",
        "!**/__tmp_*",
        "!**/unmock.spec.ts"
      ],
      "buildOptions": {
        "target": "bindings",
        "args": ["--bindings esm"]
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.bindings.js"
        }
      }
    },
    "node:wasi": {
      "buildOptions": {
        "target": "wasi"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.wasi.js"
        }
      }
    },
    "wasmtime": {
      "default": false,
      "input": [
        "assembly/__tests__/**/*.spec.ts",
        "!**/__tmp_*",
        "!**/unmock.spec.ts"
      ],
      "buildOptions": {
        "target": "wasi"
      },
      "runOptions": {
        "runtime": {
          "cmd": "wasmtime run <file>"
        }
      }
    },
    "wasmer": {
      "default": false,
      "input": [
        "assembly/__tests__/**/*.spec.ts",
        "!**/__tmp_*",
        "!**/unmock.spec.ts"
      ],
      "buildOptions": {
        "target": "wasi"
      },
      "runOptions": {
        "runtime": {
          "cmd": "wasmer run <file>"
        }
      }
    },
    "wazero": {
      "default": false,
      "input": [
        "assembly/__tests__/**/*.spec.ts",
        "!**/__tmp_*",
        "!**/unmock.spec.ts"
      ],
      "buildOptions": {
        "target": "wasi"
      },
      "runOptions": {
        "runtime": {
          "cmd": "wazero run <file>"
        }
      }
    },
    "firefox": {
      "default": false,
      "buildOptions": {
        "target": "web"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.web.js <file>",
          "browser": "firefox"
        }
      }
    },
    "chromium": {
      "default": false,
      "buildOptions": {
        "target": "web"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.web.js <file>",
          "browser": "chromium"
        }
      }
    },
    "webkit": {
      "default": false,
      "buildOptions": {
        "target": "web"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.web.js <file>",
          "browser": "webkit"
        }
      }
    },
    "firefox:headless": {
      "default": false,
      "buildOptions": {
        "target": "web"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.web.js --headless <file>",
          "browser": "firefox"
        }
      }
    },
    "chromium:headless": {
      "default": false,
      "buildOptions": {
        "target": "web"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.web.js --headless <file>",
          "browser": "chromium"
        }
      }
    },
    "webkit:headless": {
      "default": false,
      "buildOptions": {
        "target": "web"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.web.js --headless <file>",
          "browser": "webkit"
        }
      }
    }
  },
  "runOptions": {
    "runtime": {
      "cmd": "node .as-test/runners/default.wasi.js"
    },
    "reporter": "default"
  }
}
