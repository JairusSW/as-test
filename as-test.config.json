{
  "$schema": "node_modules/as-test/as-test.config.schema.json",
  "input": [
    "assembly/__tests__/*.spec.ts"
  ],
  "output": ".as-test/",
  "config": "none",
  "coverage": true,
  "env": {},
  "buildOptions": {
    "target": "wasi"
  },
  "runOptions": {
    "runtime": {
      "cmd": "node .as-test/runners/default.wasi.js <file>"
    },
    "reporter": "default"
  },
  "modes": {
    "web-headless": {
      "buildOptions": {
        "target": "web"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.web.js --headless <file>"
        }
      }
    }
  }
}
