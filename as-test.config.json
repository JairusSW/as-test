{
  "$schema": "node_modules/as-test/as-test.config.schema.json",
  "input": ["assembly/__tests__/*.spec.ts"],
  "output": ".as-test/",
  "config": "none",
  "coverage": false,
  "env": {},
  "fuzz": {
    "input": ["assembly/__fuzz__/*.fuzz.ts"],
    "runs": 1000,
    "seed": 1337,
    "maxInputBytes": 4096,
    "target": "bindings",
    "corpusDir": ".as-test/fuzz/corpus",
    "crashDir": ".as-test/crashes"
  },
  "buildOptions": {
    "target": "wasi"
  },
  "modes": {
    "node-bindings": {
      "buildOptions": {
        "target": "bindings"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.bindings.js <file>"
        }
      }
    },
    "node-wasi": {
      "buildOptions": {
        "target": "wasi"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.wasi.js <file>"
        }
      }
    },
    "wasmtime-wasi": {
      "buildOptions": {
        "target": "wasi"
      },
      "runOptions": {
        "runtime": {
          "cmd": "wasmtime run --dir . <file>"
        }
      }
    }
  },
  "runOptions": {
    "runtime": {
      "cmd": "node .as-test/runners/default.wasi.js <file>"
    },
    "reporter": "default"
  }
}
