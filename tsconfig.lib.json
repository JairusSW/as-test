{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "rootDir": "./lib/src",
    "outDir": "./lib/build",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["./lib/src/**/*.ts"]
}
