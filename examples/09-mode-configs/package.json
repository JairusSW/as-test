{
  "name": "as-test-example-09-mode-configs",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:default && npm run test:inline && npm run test:file",
    "test:default": "as-test test --config ./as-test.config.root.json",
    "test:inline": "as-test test --mode bindings-inline",
    "test:file": "as-test test --mode bindings-file",
    "test:fuzz": "as-test fuzz --config ./as-test.config.root-fuzz.json --mode root-fuzz --runs 10",
    "test:fuzz:inline": "as-test fuzz --mode bindings-inline --runs 10",
    "test:fuzz:file": "as-test fuzz --mode bindings-file --runs 10"
  },
  "devDependencies": {
    "@assemblyscript/wasi-shim": "^0.1.0",
    "as-test": "file:../..",
    "assemblyscript": "^0.28.9"
  }
}
