{
  "name": "as-test-example-08-json-as-runner-compare",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run compare",
    "test:as-test": "as-test test --parallel",
    "test:as-pect": "npm run test:aspect:prepare && npm run test:aspect:naive && npm run test:aspect:swar && npm run test:aspect:simd",
    "test:aspect:prepare": "node ./scripts/prepare-as-pect-tests.mjs",
    "test:aspect:naive": "npm run test:aspect:prepare && JSON_MODE=NAIVE node ./node_modules/@as-pect/cli/lib/test.js --config ./as-pect.config.js --as-config ./compare-runners/as-pect/naive.asconfig.json --summary --no-logo",
    "test:aspect:swar": "npm run test:aspect:prepare && JSON_MODE=SWAR node ./node_modules/@as-pect/cli/lib/test.js --config ./as-pect.config.js --as-config ./compare-runners/as-pect/swar.asconfig.json --summary --no-logo",
    "test:aspect:simd": "npm run test:aspect:prepare && JSON_MODE=SIMD node ./node_modules/@as-pect/cli/lib/test.js --config ./as-pect.config.js --as-config ./compare-runners/as-pect/simd.asconfig.json --summary --no-logo",
    "compare": "node ./scripts/compare-test-runners.mjs"
  },
  "devDependencies": {
    "@as-pect/cli": "^8.1.0",
    "@assemblyscript/wasi-shim": "^0.1.0",
    "as-test": "file:../..",
    "assemblyscript": "^0.28.9",
    "json-as": "1.3.1"
  }
}
