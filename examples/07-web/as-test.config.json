{
  "$schema": "./node_modules/as-test/as-test.config.schema.json",
  "input": ["./assembly/__tests__/*.spec.ts"],
  "outDir": "./.as-test/build",
  "logs": "./.as-test/logs",
  "coverageDir": "./.as-test/coverage",
  "snapshotDir": "./.as-test/snapshots",
  "config": "./asconfig.json",
  "coverage": true,
  "env": {},
  "buildOptions": {
    "cmd": "",
    "args": [],
    "target": "bindings"
  },
  "runOptions": {
    "runtime": {
      "cmd": "node ./.as-test/runners/default.web.js <file>"
    }
  },
  "modes": {
    "web-headless": {
      "runOptions": {
        "runtime": {
          "cmd": "node ./.as-test/runners/default.web.js --headless <file>"
        }
      }
    }
  }
}
