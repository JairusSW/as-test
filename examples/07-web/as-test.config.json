{
  "$schema": "./node_modules/as-test/as-test.config.schema.json",
  "input": ["./assembly/__tests__/*.spec.ts"],
  "output": ".as-test/",
  "config": "./asconfig.json",
  "coverage": true,
  "env": {},
  "buildOptions": {
    "target": "bindings"
  },
  "runOptions": {
    "runtime": {
      "cmd": "node .as-test/runners/default.web.js"
    }
  },
  "modes": {
    "web-headless": {
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.web.js --headless"
        }
      }
    }
  }
}
