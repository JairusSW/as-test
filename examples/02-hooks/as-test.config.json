{
  "$schema": "./node_modules/as-test/as-test.config.schema.json",
  "input": ["./assembly/__tests__/*.spec.ts"],
  "output": ".as-test/",
  "config": "./asconfig.json",
  "coverage": true,
  "env": {},
  "buildOptions": {
    "target": "wasi"
  },
  "modes": {
    "wasi": {
      "buildOptions": {
        "target": "wasi"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.wasi.js"
        }
      }
    },
    "bindings": {
      "buildOptions": {
        "target": "bindings"
      },
      "runOptions": {
        "runtime": {
          "cmd": "node .as-test/runners/default.bindings.js"
        }
      }
    }
  },
  "runOptions": {
    "runtime": {
      "cmd": "node .as-test/runners/default.wasi.js"
    }
  }
}
